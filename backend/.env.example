# ===== Backend (FastAPI) =====

# Entorno
APP_ENV=development

# Supabase (PostgreSQL) — https://supabase.com  →  Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=tu_service_role_o_anon_key

# Google Gemini (reconocimiento multimodal) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.0-flash

# Seguridad / autenticación (RF-07)
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
JWT_EXPIRE_MINUTES=480

# CORS — orígenes permitidos del frontend (separados por coma)
CORS_ORIGINS=http://localhost:3000
