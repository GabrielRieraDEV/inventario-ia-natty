# ===== Backend (FastAPI) =====

# Entorno
APP_ENV=development

# Supabase (PostgreSQL) — https://supabase.com  →  Project Settings → API
# El backend usa la clave SECRET / service_role (formato nuevo: sb_secret_…).
# NO uses aquí la anon/publishable; esa va solo en el frontend.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# Google Gemini (reconocimiento multimodal) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.5-flash

# Seguridad / autenticación (RF-07)
JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
JWT_EXPIRE_MINUTES=480

# CORS — orígenes permitidos del frontend (separados por coma).
# En producción agrega el dominio de Vercel, p. ej.:
# CORS_ORIGINS=http://localhost:3000,https://inventario-ia-natty.vercel.app
CORS_ORIGINS=http://localhost:3000

# Sesión de captura por QR: minutos de validez del token (anti-abuso de la IA)
SESION_TTL_MINUTOS=30
# Alertas: días de anticipación para avisar de un producto por vencer
VENCIMIENTO_DIAS_ALERTA=30
