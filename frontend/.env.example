# ===== Frontend (Next.js) =====

# URL del backend FastAPI.
# Local: http://localhost:8003  (ver gotcha de puertos en CLAUDE.md)
# Producción: la URL pública del servicio en Render, p. ej.
#   https://inventario-ia-natty-api.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:8003

# Supabase (cliente público) — clave ANON / publishable (formato nuevo: sb_publishable_…)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
